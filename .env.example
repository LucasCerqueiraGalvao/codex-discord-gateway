DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_ALLOWED_USER_ID=123456789012345678
DISCORD_ALLOWED_CHANNEL_ID=123456789012345678

# Optional: if empty, bot tries known defaults in this order:
# 1) codex exec --skip-git-repo-check --json
# 2) codex exec --json
# 3) codex exec --skip-git-repo-check
# 4) codex exec
CODEX_CMD=
CODEX_TIMEOUT_SECONDS=120
CODEX_WORKDIR=

DISCORD_CHUNK_SIZE=1900
LOG_LEVEL=INFO
LOG_DIR=logs
